database -open waves -into waves.shm -default
probe -create -shm tb_bidirectional_bus_driver.r_bus_drive_data tb_bidirectional_bus_driver.i_data_to_bus tb_bidirectional_bus_driver.i_rcv tb_bidirectional_bus_driver.i_send tb_bidirectional_bus_driver.io_bus_data tb_bidirectional_bus_driver.o_data_from_bus
run
exit
